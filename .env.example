# ── SolRouter API Key (primary — encrypted inference via Nosana)
# Get yours at solrouter.com
SOLROUTER_API_KEY=sk_solrouter_YOURKEYHERE

# ── Groq API Key (FREE fallback — get yours at console.groq.com)
# Free tier: 14,400 requests/day — no credit card needed
GROQ_API_KEY=gsk_YOURKEYHERE

# ── Anthropic Claude API Key (optional fallback)
# Get yours at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-YOURKEYHERE

# ── Solana RPC
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Wallet to scan (CLI mode only)
WALLET_ADDRESS=YOUR_SOLANA_WALLET_ADDRESS