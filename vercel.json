{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/scan", "dest": "/api/scan.js", "methods": ["POST", "OPTIONS"] },
    { "src": "/api/compare", "dest": "/api/compare.js", "methods": ["POST", "OPTIONS"] },
    { "src": "/api/health", "dest": "/api/health.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/*.js": { "maxDuration": 60 }
  }
}
